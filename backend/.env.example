# ─── Database ────────────────────────────────────────────────────────────────
# Railway auto-injects DATABASE_URL — copy it from your Railway DB service
DATABASE_URL=postgresql://user:password@host:5432/railway

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secure-secret-minimum-32-chars

# ─── Plaid ───────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_or_production_secret
PLAID_ENV=sandbox
# Mobile Link (register package name + redirect URI in Plaid Dashboard → Team → API)
# Android: required for OAuth institutions when using the React Native SDK
PLAID_ANDROID_PACKAGE_NAME=io.worthiq.app
# iOS: optional in sandbox; production OAuth (e.g. Chase) needs https redirect + Universal Links
# PLAID_IOS_REDIRECT_URI=https://worthiq.io/plaid-oauth

# ─── Email (Gmail App Password) ──────────────────────────────────────────────
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Public site URL (password reset links, CORS) ───────────────────────────
# Must match where users open the app — NOT api.worthiq.io
# Production: https://worthiq.io  (or https://www.worthiq.io if that’s canonical)
FRONTEND_URL=https://worthiq.io

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
