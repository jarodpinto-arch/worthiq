# ─── Database ────────────────────────────────────────────────────────────────
# Railway auto-injects DATABASE_URL — copy it from your Railway DB service
DATABASE_URL=postgresql://user:password@host:5432/railway

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secure-secret-minimum-32-chars

# ─── Plaid ───────────────────────────────────────────────────────────────────
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_sandbox_or_production_secret
PLAID_ENV=sandbox

# ─── Email (Gmail App Password) ──────────────────────────────────────────────
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── CORS — set to your Vercel frontend URL in production ────────────────────
FRONTEND_URL=https://worthiq.vercel.app

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
