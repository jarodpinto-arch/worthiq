# WorthIQ Frontend Environment Variables
# Copy this file to .env.local for local development

# API Configuration
# Local: talk to Nest on your machine
NEXT_PUBLIC_API_URL=http://localhost:3001

# Production (Vercel): same-origin proxy — no browser CORS to Railway
#   NEXT_PUBLIC_API_URL=/api/backend
#   BACKEND_URL=https://your-service.up.railway.app
# BACKEND_URL is server-only (Next route /api/backend/* proxies to Nest); do not use NEXT_PUBLIC_ for it.
#
# Smoke tests after deploy:
#   GET /api/health              → Next only (proves API routes work)
#   GET /api/health?deep=1      → Vercel server fetch to BACKEND_URL/health (end-to-end)
#   GET /api/probe              → same (if some CDN blocks "diagnostic", use this)
#   GET /api/backend/health      → proxied to Nest on Railway

# Plaid Configuration
REACT_APP_PLAID_ENV=sandbox

# App Info
REACT_APP_NAME=WorthIQ
REACT_APP_VERSION=1.0.0
